{
  "name": "fastscraper-js",
  "version": "0.0.1-alpha.1",
  "description": "Fast HTML parser with CSS selector API, powered by Rust",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "browser": "./browser.js",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/pycabbage/fastscraper-js.git"
  },
  "author": {
    "name": "Cabbage Lettuce",
    "email": "33714346+pycabbage@users.noreply.github.com",
    "url": "https://github.com/pycabbage/"
  },
  "license": "MIT",
  "keywords": [
    "napi-rs",
    "NAPI",
    "N-API",
    "Rust",
    "node-addon",
    "node-addon-api"
  ],
  "files": [
    "index.d.ts",
    "index.js",
    "browser.js"
  ],
  "napi": {
    "binaryName": "fastscraper-js",
    "targets": [
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "wasm32-wasip1-threads"
    ]
  },
  "engines": {
    "node": ">= 18.17.0 < 19 || >= 20.3.0 < 21 || >= 21.1.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "pnpm --filter @fastscraper-js/benchmark bench",
    "build": "napi build --esm --platform --release",
    "build:debug": "napi build --esm --platform",
    "format": "run-p format:rs format:toml",
    "format:toml": "taplo format",
    "format:rs": "cargo fmt",
    "lint": "biome check",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "vitest run",
    "preversion": "napi build --esm --platform && git add .",
    "version": "napi version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.2.0",
    "@napi-rs/wasm-runtime": "^1.1.6",
    "@taplo/cli": "^0.7.0",
    "@tybys/wasm-util": "^0.10.0",
    "@types/jsdom": "^28.0.3",
    "cheerio": "^1.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "linkedom": "^0.18.12",
    "lint-staged": "^17.0.0",
    "node-html-parser": "^8.0.3",
    "npm-run-all2": "^9.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  }
}
